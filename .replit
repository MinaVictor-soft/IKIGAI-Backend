entrypoint = "src/app.ts"
run = "npm run dev"
modules = ["nodejs-20"]

[nix]
channel = "unstable"

[env]
NODE_ENV = "production"
PORT = "3000"
DATABASE_URL = "postgresql://postgres:password@helium:5432/heliumdb"
JWT_SECRET = "ikigai-quest-secret-key-change-this"

[packager]
language = "nodejs"

[[ports]]
localPort = 3000
externalPort = 80

[userenv]

[userenv.shared]
NODE_ENV = "development"
JWT_SECRET = "ikigai-quest-secret-key-change-in-production"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "DATABASE_URL=postgresql://$PGUSER:$PGPASSWORD@$PGHOST:$PGPORT/$PGDATABASE ./node_modules/.bin/tsx watch src/app.ts"
waitForPort = 3000

[agent]
expertMode = true

[deployment]
deploymentTarget = "autoscale"
run = ["node", "dist/app.js"]
build = ["npm", "run", "build"]
